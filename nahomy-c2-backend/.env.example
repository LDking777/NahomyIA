# Servidor
PORT=3000
NODE_ENV=development

# Base de Datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=nahomy
DB_PASSWORD=nahomy_secret
DB_NAME=nahomy_c2
DB_SSL=false

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=c2.events

# JWT
JWT_SECRET=nahomy-c2-secret-key-change-in-production
JWT_EXPIRES_IN=8h
